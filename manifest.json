{
  "manifest_version": 3,
  "name": "UNIPA Guardian",
  "version": "2.2.1",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "options.html",
    "default_title": "UNIPA Guardian 設定"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "host_permissions": [
    "https://unipa.u-hyogo.ac.jp/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://unipa.u-hyogo.ac.jp/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}