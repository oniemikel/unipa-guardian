{
  "manifest_version": 3,
  "name": "UNIPA Session Guardian",
  "version": "1.1",
  "description": "UNIPAのセッションを掌握し、入力内容を保護します",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://unipa.u-hyogo.ac.jp/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://unipa.u-hyogo.ac.jp/uprx/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}